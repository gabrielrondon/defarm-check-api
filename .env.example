# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/check_api

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# API Security
API_SECRET=your-secret-key-here
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# External APIs
GOOGLE_MAPS_API_KEY=
INPE_API_KEY=
MTE_API_KEY=
CGU_API_KEY=

# Satellite Imagery APIs (see docs/SATELLITE_IMAGERY_ROADMAP.md)
# MapBiomas Alerta — territory intelligence + deforestation alerts (free account at plataforma.alerta.mapbiomas.org)
MAPBIOMAS_EMAIL=
MAPBIOMAS_PASSWORD=
# NASA Earthdata JWT — NDVI/GPP time-series via APPEEARS (token from urs.earthdata.nasa.gov)
NASA_EARTHDATA_TOKEN=
# Sentinel Hub — on-demand Sentinel-2 NDVI (paid, sentinel-hub.com)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Cache
CACHE_ENABLED=true
DEFAULT_CACHE_TTL=3600

# Geocoding
GEOCODING_PROVIDER=nominatim
GEOCODING_CACHE_TTL=31536000
GEOCODING_RATE_LIMIT=1

# Telegram Bot (Worker Service)
TELEGRAM_BOT_TOKEN=8226739998:AAF7LkcRUlYQiFlM1cmbNo6sC49Cu-SME2Y
TELEGRAM_CHAT_ID=459514238
